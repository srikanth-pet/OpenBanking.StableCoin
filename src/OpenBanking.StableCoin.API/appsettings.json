{
  "ConnectionStrings": {
    "StablecoinDb": "Host=localhost;Database=stablecoin;Username=postgres;Password=REPLACE_ME"
  },
  "Coinbase": {
    "ApiKeyName": "organizations/{org_id}/apiKeys/{key_id}",
    "PrivateKeyPem": "REPLACE_WITH_ED25519_PRIVATE_KEY_PEM_FROM_ENVIRONMENT",
    "WebhookSecret": "REPLACE_WITH_WEBHOOK_SECRET_FROM_ENVIRONMENT",
    "DefaultProductId": "USDC-USD",
    "SupportedNetworks": [ "base-mainnet", "ethereum-mainnet", "polygon-mainnet" ],
    "AdvancedTradeBaseUrl": "https://api.coinbase.com/api/v3/brokerage/",
    "CdpWalletBaseUrl": "https://api.cdp.coinbase.com/platform/v1/"
  },
  "Banking": {
    "Jwt": {
      "Authority": "https://auth.openbanking.internal",
      "Audience": "stablecoin-api"
    }
  },
  "RateLimiting": {
    "PerCustomerWindowSeconds": 60,
    "PerCustomerPermitLimit": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
